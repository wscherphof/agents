# Project configuration for the agents launcher.
#
# These values point this branch at the project (and component) it drives. They
# are committed per project/component branch and are what make a branch
# project-specific. On the `main` template branch they are blank; set them when
# branching off to onboard a new project/component.
#
# This file is read by .claude/hooks/session-start.sh.

# Mandatory!
AGENTS_GIT_ACCOUNT=merkatordev
# e.g. AGENTS_GIT_ACCOUNT=merkatordev

# Mandatory!
AGENTS_GIT_REPO=infrabelow
# e.g. AGENTS_GIT_REPO=GeoWEP

# Optional (for a component in a monorepo).
AGENTS_COMPONENT_DIR=
# e.g. AGENTS_COMPONENT_DIR=components/geowep-ng

# Optional. Name of the project repo's integration branch to target PRs at (if
# it exists) instead of the checked-out default (main/master). When blank, PRs
# target the default branch (main/master) as usual.
AGENTS_INTEGRATION_BRANCH=
# e.g. AGENTS_INTEGRATION_BRANCH=develop

# Optional. Set to true to start the Docker daemon at session start. The
# container image must already have Docker installed.
AGENTS_START_DOCKER=
# e.g. AGENTS_START_DOCKER=true

# Optional. Override the settings branch that merge-agent-settings.sh mirrors
# the auto-merged agent settings to. Leave BLANK for normal project/component
# sessions: the branch is then derived from the repo (+ optional component),
# e.g. GeoWEP + docker/ng -> geowep-ng, which is what you almost always want.
# Only set it for edge cases where the derived name is not the desired target —
# here, a dedicated test branch so exercising the session-start hook doesn't
# touch the live geowep-ng settings branch.
AGENTS_SETTINGS_BRANCH=
# e.g. AGENTS_SETTINGS_BRANCH=geowep-ng-test
