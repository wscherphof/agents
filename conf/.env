# Project configuration for the agents launcher.
#
# These values point this branch at the project (and component) it drives. They
# are committed per project/component branch and are what make a branch
# project-specific. On the `main` template branch they are blank; set them when
# branching off to onboard a new project/component.
#
# This file is read by .claude/hooks/session-start.sh.

# Mandatory!
AGENTS_GIT_ACCOUNT=merkatordev
# e.g. AGENTS_GIT_ACCOUNT=merkatordev

# Mandatory!
AGENTS_GIT_REPO=GeoWEP
# e.g. AGENTS_GIT_REPO=GeoWEP

# Optional (for a component in a monorepo).
AGENTS_COMPONENT_DIR=
# e.g. AGENTS_COMPONENT_DIR=components/geowep-ng

# Optional. Set to true to start the Docker daemon at session start. The
# container image must already have Docker installed.
AGENTS_START_DOCKER=true
# e.g. AGENTS_START_DOCKER=true
